            "  State 1: ACGTACTG\n",
            "  State 2: ACGTAGCT\n",
            "  State 3: ACGTAGTC\n",
            "  State 4: ACGTATCG\n"
          ]
        }
      ],
      "source": [
        "# Basic usage\n",
        "original_seq = 'ACGTACGT'\n",
        "shuffler = ShuffledPool(seq=original_seq)\n",
        "\n",
        "print(f\"Original sequence: {original_seq}\")\n",
        "print(f\"Number of states: {shuffler.num_states} (8! = 40,320)\")\n",
        "print(f\"Is finite: {shuffler.is_sequential_compatible()}\")\n",
        "print(\"\\nGenerated shuffled sequences:\")\n",
        "for i in range(5):\n",
        "    shuffler.set_state(i)\n",
        "    print(f\"  State {i}: {shuffler.seq}\")\n"
      ]
