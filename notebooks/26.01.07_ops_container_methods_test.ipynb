   "source": [
    "import poolparty as pp; pp.init()\n",
    "\n",
    "bg_pool = pp.from_seq('A'*8)\n",
    "\n",
    "result_pool = bg_pool.mutagenize_scan(mutagenize_length=5, num_mutations=1, mode='sequential', spacer_str='.')\n",
    "\n",
    "print('final counter')\n",
    "result_pool.counter.print_tree()\n",
    "\n",
    "print('final library')\n",
    "result_pool.print_library()\n",
    "\n"
